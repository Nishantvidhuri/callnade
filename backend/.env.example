NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/chatmeet
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

REDIS_URL=redis://127.0.0.1:6379

S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
CDN_BASE_URL=

TURN_SECRET=
TURN_HOST=
TURN_TTL_SEC=600

# Razorpay (https://dashboard.razorpay.com/app/keys). KEY_SECRET stays
# server-side; KEY_ID is the public identifier sent to the browser.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
