NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/chatmeet
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

REDIS_URL=redis://127.0.0.1:6379

S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
CDN_BASE_URL=

# coturn (TURN/STUN relay).
# - TURN_SECRET must match `static-auth-secret` in /etc/turnserver.conf.
#   Generate with: openssl rand -hex 32
# - TURN_HOST is the public hostname:port the browser will connect to
#   (e.g. callnade.site:3478). Cert SAN must cover this hostname.
# - TURN_TTL_SEC is how long minted credentials stay valid (default 600s).
# When both _SECRET and _HOST are set, the backend mints time-limited
# HMAC-signed creds in coturn's `use-auth-secret` format. When empty,
# the ICE config falls back to STUN only.
TURN_SECRET=
TURN_HOST=
TURN_TTL_SEC=600

# Razorpay (https://dashboard.razorpay.com/app/keys). KEY_SECRET stays
# server-side; KEY_ID is the public identifier sent to the browser.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
